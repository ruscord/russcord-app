{
  "name": "russcord-app",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop-клиент Russcord (Electron)",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:signed": "electron-builder",
    "pack": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "pack:signed": "electron-builder --dir",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:signed": "electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^25.1.8"
  }
}
